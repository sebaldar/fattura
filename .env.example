# Postgres (container interno, nessuna porta esposta verso l'host)
POSTGRES_DB=fattura
POSTGRES_USER=fattura
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://fattura:changeme@postgres:5432/fattura

# MariaDB legacy (mysql.baldoweb.it, SOLA LETTURA)
LEGACY_DB_HOST=mysql.baldoweb.it
LEGACY_DB_PORT=3306
LEGACY_DB_USER=changeme
LEGACY_DB_PASSWORD=changeme
LEGACY_DB_DATABASE=changeme

# Anthropic (estrazione dati cliente da foto) - solo lato backend
ANTHROPIC_API_KEY=changeme

# Auth
JWT_SECRET=changeme-min-32-caratteri-casuali
TOTP_ENC_KEY=changeme-min-32-caratteri-casuali

# Seed utente admin (nessuna registrazione pubblica: creazione solo via seed/script CLI)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme-password-forte

# Frontend -> Backend (rete Docker interna, di norma non serve cambiarlo)
BACKEND_INTERNAL_URL=http://backend:3005

# URL pubblico dell'app (dietro il reverse proxy)
NEXT_PUBLIC_APP_URL=https://fattura.example.com
