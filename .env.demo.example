# Ambiente demo pubblica (docker-compose.demo.yml) — stack separato da
# .env.example/docker-compose.yml, nessun dato reale. Copia in .env.demo
# e compila.

# Postgres demo (volume pgdata_demo, indipendente dalla produzione)
POSTGRES_DB=fattura_demo
POSTGRES_USER=fattura_demo
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://fattura_demo:changeme@postgres:5432/fattura_demo

# MariaDB "legacy" demo: catalogo fittizio caricato da
# demo/mariadb-legacy/init.sql al primo avvio, non è il legacy reale.
MARIADB_DEMO_ROOT_PASSWORD=changeme
LEGACY_DB_USER=fattura_demo
LEGACY_DB_PASSWORD=changeme
LEGACY_DB_DATABASE=legacy_demo
# LEGACY_DB_HOST e LEGACY_DB_PORT sono impostati direttamente in
# docker-compose.demo.yml (mariadb-legacy:3306), non vanno duplicati qui.

# Anthropic (estrazione dati cliente da foto) - solo lato backend
ANTHROPIC_API_KEY=changeme

# Auth — usa segreti DIVERSI da quelli di produzione: questa istanza è
# pubblica e più esposta.
JWT_SECRET=changeme-min-32-caratteri-casuali
TOTP_ENC_KEY=changeme-min-32-caratteri-casuali

# Seed demo: crea l'utente admin demo + emittente fittizio + clienti/
# documenti di esempio (vedi backend/src/db/seed-demo.ts)
ADMIN_EMAIL=demo@example.com
ADMIN_PASSWORD=changeme-password-forte

# Frontend -> Backend (rete Docker interna del progetto fattura-demo)
BACKEND_INTERNAL_URL=http://backend:3005

# URL pubblico della demo
NEXT_PUBLIC_APP_URL=https://demo.fattura.mondobimbi.com
